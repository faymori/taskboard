# =========================================================================
# Dependency Directories (โฟลเดอร์เก็บไลบรารี ห้าม Commit)
# =========================================================================
node_modules/
backend/node_modules/
frontend/node_modules/
jspm_packages/
web_modules/

# =========================================================================
# Environment Variables (ไฟล์เก็บความลับ/คีย์ต่างๆ ห้าม Commit เด็ดขาด!)
# =========================================================================
.env
.env.*
!.env.example
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# =========================================================================
# Build Outputs (ไฟล์ที่ได้จากการคอมไพล์ ห้าม Commit)
# =========================================================================
dist/
build/
backend/dist/
backend/build/
frontend/dist/
frontend/build/
.next/
out/
.nuxt/
.output/

# =========================================================================
# Logs and System Files (ไฟล์บันทึกการทำงานและไฟล์ระบบเครื่อง)
# =========================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db

# =========================================================================
# Caches and Diagnostics (ไฟล์แคชต่างๆ)
# =========================================================================
.cache/
.parcel-cache/
.eslintcache/
.stylelintcache/
*.tsbuildinfo
pids/
*.pid